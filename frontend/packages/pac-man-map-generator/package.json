{
  "name": "@parkerstovall.com/pac-man-map-generator",
  "version": "1.1.5",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "tsc && eslint ./src --fix",
    "test": "vitest run",
    "patch": "npm version patch --no-git-tag-version",
    "minor": "npm version minor --no-git-tag-version",
    "major": "npm version major --no-git-tag-version",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/markdown": "^8.0.2",
    "@microsoft/api-extractor": "^7.58.7",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "pacman",
    "map",
    "generator",
    "game"
  ],
  "author": "parkerstovall",
  "license": "MIT",
  "description": "Generates a random pacman map",
  "bugs": {
    "url": "https://github.com/parkerstovall/pac-man-map-generator/issues"
  },
  "homepage": "https://github.com/parkerstovall/pac-man-map-generator",
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": false,
    "printWidth": 80
  }
}
